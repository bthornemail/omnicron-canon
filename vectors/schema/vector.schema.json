{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omnicron-canon/vectors/vector.schema.json",
  "title": "Omnicron Conformance Vector",
  "description": "Schema for Omnicron conformance vector files",
  "type": "object",
  "required": ["schema", "version", "vectors"],
  "properties": {
    "schema": {
      "type": "string",
      "description": "Schema identifier"
    },
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "vectors": {
      "type": "array",
      "description": "Array of conformance vectors",
      "items": {
        "$ref": "#/$defs/vector"
      }
    },
    "invariants": {
      "type": "array",
      "description": "Array of invariants that must hold",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "vector": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique vector identifier"
        },
        "description": {
          "type": "string",
          "description": "Optional description"
        },
        "input": {
          "type": "object",
          "description": "Input values"
        },
        "encoded": {
          "description": "Encoded value"
        },
        "expected": {
          "type": "object",
          "description": "Expected results"
        }
      }
    }
  }
}
